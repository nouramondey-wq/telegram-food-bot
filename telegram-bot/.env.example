# ══════════════════════════════════════════════════════════════
# Telegram Restaurant Bot — Environment Configuration
# ══════════════════════════════════════════════════════════════
#
# DEVELOPMENT:   Copy to .env and fill in values
# PRODUCTION:    Set these in Render Dashboard
#
# ══════════════════════════════════════════════════════════════

# ── Telegram Bot Configuration ──────────────────────────────

# Bot Token from BotFather (SECRET)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_USERNAME=@NourNasserfoodBot

# Bot Mode: polling (dev) or webhook (production on Render)
BOT_MODE=polling

# Webhook URL (auto-detected from RENDER_EXTERNAL_URL in production)
WEBHOOK_URL=

# Secret token for webhook validation (openssl rand -hex 32)
WEBHOOK_SECRET=

# ── Firebase Admin SDK ──────────────────────────────────────

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your-key-here...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# ── Mini App ────────────────────────────────────────────────

MINI_APP_URL=https://my-restaurant-app-de879.web.app
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ── Restaurant Info ─────────────────────────────────────────

RESTAURANT_NAME=Restaurant Name
RESTAURANT_PHONE=+966500000000
RESTAURANT_ADDRESS=Riyadh
RESTAURANT_LATITUDE=24.7136
RESTAURANT_LONGITUDE=46.6753
RESTAURANT_HOURS=Sat-Thu: 8:00 AM - 11:00 PM\nFri: Closed
RESTAURANT_INSTAGRAM=

# ── Admin Notifications ─────────────────────────────────────

ADMIN_CHAT_IDS=

# ── Security ────────────────────────────────────────────────

RATE_LIMIT_MAX=5
RATE_LIMIT_BLOCK=30
