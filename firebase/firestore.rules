rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // دوال مساعدة
    // ============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.email != null
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.email == request.auth.token.email;
    }

    // ============================================================
    // الطلبات - Orders
    // ============================================================
    match /orders/{orderId} {
      // أي شخص يمكنه إنشاء طلب (من داخل التطبيق)
      allow create: if true;

      // القراءة مفتوحة — الأمان يتم عبر الفلتر في الكود (customer.telegram_id)
      allow read: if true;

      // التعديل: يسمح فقط بإلغاء الطلبات قيد الانتظار
      allow update: if isAdmin()
          || (resource.data.status == 'pending'
              && request.resource.data.status == 'cancelled');

      // الحذف: المشرفون فقط
      allow delete: if isAdmin();
    }

    // ============================================================
    // عناصر القائمة - Menu Items
    // ============================================================
    match /menu_items/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ============================================================
    // الفئات - Categories
    // ============================================================
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ============================================================
    // الإعدادات - Settings
    // ============================================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if settingId == 'order_counter' || isAdmin();
    }

    // ============================================================
    // المشرفون - Admins
    // ============================================================
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // ============================================================
    // منع كل شيء آخر
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
